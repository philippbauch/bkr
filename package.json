{
  "name": "bkr",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build:api": "nx build api",
    "build:api:prod": "nx build api -c production",
    "build:web": "nx build web",
    "build:web:prod": "nx build web -c production",
    "format:check": "nx format:check",
    "format:check:all": "nx format:check --all",
    "format:write": "nx format:write",
    "format:write:all": "nx format:write --all",
    "lint": "nx affected:lint",
    "lint:all": "nx affected:lint --all",
    "migrate:reset": "prisma migrate reset --force",
    "postinstall": "ngcc --properties es2020 browser module main",
    "start:all": "nx run-many --target=serve --projects=api,web --parallel",
    "start:api": "nx serve api",
    "start:web": "nx serve web",
    "start": "npm run start:all",
    "test:api": "nx test api",
    "test:api:coverage": "nx test api --codeCoverage --coverageReporters=\"text-summary\""
  },
  "private": true,
  "devDependencies": {
    "@nrwl/cli": "14.5.10",
    "@nrwl/eslint-plugin-nx": "14.5.10",
    "@nrwl/express": "^14.5.10",
    "@nrwl/jest": "14.5.10",
    "@nrwl/linter": "14.5.10",
    "@nrwl/node": "14.5.10",
    "@nrwl/workspace": "14.5.10",
    "@trivago/prettier-plugin-sort-imports": "^3.3.0",
    "@types/cors": "^2.8.12",
    "@types/express": "4.17.13",
    "@types/jest": "27.4.1",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/node": "16.11.7",
    "@typescript-eslint/eslint-plugin": "^5.29.0",
    "@typescript-eslint/parser": "^5.29.0",
    "eslint": "~8.15.0",
    "eslint-config-prettier": "8.1.0",
    "jest": "27.5.1",
    "nx": "14.5.10",
    "prettier": "^2.6.2",
    "prisma": "^4.2.1",
    "ts-jest": "27.1.4",
    "ts-node": "10.9.1",
    "typescript": "~4.7.2"
  },
  "dependencies": {
    "@prisma/client": "^4.2.1",
    "cors": "^2.8.5",
    "express": "^4.18.1",
    "helmet": "^6.0.0",
    "joi": "^17.6.0",
    "jsonwebtoken": "^8.5.1",
    "socket.io": "^4.5.1",
    "tslib": "^2.3.0"
  }
}
